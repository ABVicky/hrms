# Netlify Headers for ASPIRE PWA
# Documentation: https://docs.netlify.com/routing/headers/

# Cache Control for PWA Service Worker (Crucial for updates)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  X-Content-Type-Options: nosniff

# Cache Control for Main HTML (Prevents stale UI)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Cache Control for Manifest
/manifest.json
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache

# Immutable Caching for Static Assets (Next.js Hashed Files)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Cache Control for Common Assets
/*.png
  Cache-Control: public, max-age=86400

/*.ico
  Cache-Control: public, max-age=86400
